---
import Layout from '../layouts/Layout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { localBusinessSchema } from '../components/SchemaOrg.astro';
import { Image } from 'astro:assets';

const uslugiMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/uslugi/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);
const schodMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/schody/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);

function pickImg(
  mods: Record<string, { default: ImageMetadata }>,
  name: string
): ImageMetadata | null {
  const entry = Object.entries(mods).find(([k]) => k.split('/').pop()?.startsWith(name));
  return entry ? entry[1].default : null;
}

const imgs = {
  cyklinowanie: pickImg(uslugiMods, 'cyklinowanie'),
  lakierowanie: pickImg(uslugiMods, 'lakierowanie'),
  olejowanie:   pickImg(uslugiMods, 'olejowanie'),
  ukladanie:    pickImg(uslugiMods, 'ukladanie'),
  listwowanie:  pickImg(uslugiMods, 'listwowanie'),
  schodGlowne:  pickImg(schodMods, 'schody') ?? null,
};
---

<Layout
  title="Usługi parkieciarskie – Cyklinowanie, Lakierowanie, Schody | Książczak"
  description="Kompleksowe usługi parkieciarskie: cyklinowanie bezpyłowe, lakierowanie, olejowanie, układanie parkietu, listwowanie i schody drewniane. Ponad 25 lat doświadczenia. Bezpłatna wycena!"
  schema={localBusinessSchema}
  breadcrumbs={[{ name: 'Usługi', url: '/uslugi' }]}
>
  <!-- Header -->
  <section class="bg-stone-50 py-14 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-4 text-sm text-stone-400" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-stone-600 transition-colors">Strona główna</a></li>
          <li>/</li>
          <li class="text-stone-600" aria-current="page">Usługi</li>
        </ol>
      </nav>
      <h1 class="text-3xl font-bold text-stone-900 sm:text-4xl" data-animate>Nasze usługi parkieciarskie</h1>
      <p class="mt-4 max-w-2xl text-base text-stone-600 leading-relaxed sm:text-lg" data-animate style="transition-delay: 100ms">
        Kompleksowa obsługa podłóg drewnianych i schodów – od cyklinowania bezpyłowego, przez lakierowanie i olejowanie, po układanie nowych parkietów i schody drewniane na wymiar.
      </p>
    </div>
  </section>

  <!-- Cyklinowanie bezpyłowe -->
  <section class="section-padding bg-white" id="cyklinowanie">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="section-title" data-animate>Cyklinowanie bezpyłowe podłóg</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              Cyklinowanie bezpyłowe to <strong class="text-stone-900">szlifowanie podłóg drewnianych maszyną z systemem odsysania pyłu</strong>. Ponad 99% pyłu drzewnego jest wychwytywane bezpośrednio przy głowicy szlifierskiej – nie roznosi się po mieszkaniu.
            </p>
            <p>
              To idealne rozwiązanie dla rodzin z dziećmi, alergików i wszystkich, którzy nie chcą chaosu podczas remontu. Efekt: podłoga wyszlifowana do gołego drewna, gotowa pod lakierowanie lub olejowanie.
            </p>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-3">
            {['Parkiet dębowy', 'Deski sosnowe', 'Mozaika parkietowa', 'Podłogi warstwowe'].map(type => (
              <div class="flex items-center gap-2 text-sm text-stone-700">
                <svg class="h-4 w-4 text-green-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {type}
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-stone-50 p-4 ring-1 ring-stone-100">
            <p class="text-sm font-medium text-stone-900">Bezpłatna wycena – <a href="/kontakt" class="text-wood-600 hover:underline">skontaktuj się z nami</a></p>
            <p class="text-xs text-stone-500 mt-0.5">Dojedziemy na oględziny i bezpłatnie ocenimy stan podłogi.</p>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-2xl bg-stone-100 h-72 lg:h-96" data-animate="fade" style="transition-delay: 200ms">
          {imgs.cyklinowanie && <Image src={imgs.cyklinowanie} alt="Cyklinowanie bezpyłowe parkietu – Książczak Parkiety" class="w-full h-full object-cover" width={600} height={400} loading="lazy" format="webp" quality={82} />}
          {!imgs.cyklinowanie && <div class="absolute inset-0 flex items-center justify-center bg-stone-200/50 text-stone-400 text-sm">Zdjęcie usługi</div>}
        </div>
      </div>
    </div>
  </section>

  <!-- Lakierowanie -->
  <section class="section-padding bg-stone-50" id="lakierowanie">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div class="order-2 lg:order-1 relative overflow-hidden rounded-2xl bg-stone-100 h-72 lg:h-96" data-animate="fade" style="transition-delay: 200ms">
          {imgs.lakierowanie && <Image src={imgs.lakierowanie} alt="Lakierowanie podłogi drewnianej – Książczak Parkiety" class="w-full h-full object-cover" width={600} height={400} loading="lazy" format="webp" quality={82} />}
          {!imgs.lakierowanie && <div class="absolute inset-0 flex items-center justify-center bg-stone-200/50 text-stone-400 text-sm">Zdjęcie usługi</div>}
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 rounded-full bg-wood-50 px-4 py-1.5 text-sm font-medium text-wood-600 mb-5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 21H3a1 1 0 01-1-1v-4a1 1 0 011-1h4v6zm7-2H10v-4h4v4zm7 2h-5v-6h4a1 1 0 011 1v4a1 1 0 01-1 1zM12 3l-8 6h4v8h8v-8h4L12 3z"/></svg>
            Usługa
          </div>
          <h2 class="section-title" data-animate>Lakierowanie podłóg drewnianych</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              Lakierowanie tworzy <strong class="text-stone-900">twardą powłokę ochronną</strong> na powierzchni drewna, odporną na ścieranie, wodę i zabrudzenia. Idealne do intensywnie użytkowanych pomieszczeń: kuchni, korytarzy, salonów.
            </p>
            <p>
              Stosujemy <strong class="text-stone-900">wysokiej jakości lakiery wodne i poliuretanowe</strong> renomowanych producentów. Nakładamy 2–3 warstwy z pełnym schnięciem między nimi. Efekt: trwałość 10–15 lat.
            </p>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-3">
            {['Lakier matowy', 'Lakier satynowy', 'Lakier połysk', 'Lakier UV'].map(type => (
              <div class="flex items-center gap-2 text-sm text-stone-700">
                <svg class="h-4 w-4 text-green-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {type}
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-stone-50 p-4 ring-1 ring-stone-100">
            <p class="text-sm font-medium text-stone-900">Bezpłatna wycena – <a href="/kontakt" class="text-wood-600 hover:underline">skontaktuj się z nami</a></p>
            <p class="text-xs text-stone-500 mt-0.5">Zazwyczaj 2–3 warstwy. Dokładna wycena po oględzinach.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Olejowanie -->
  <section class="section-padding bg-white" id="olejowanie">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-amber-50 px-4 py-1.5 text-sm font-medium text-amber-700 mb-5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.78 2.2L22 4.42 11.68 14.74c.42.58.68 1.29.68 2.06 0 1.93-1.57 3.5-3.5 3.5S5.36 18.73 5.36 16.8c0-1.93 1.57-3.5 3.5-3.5.77 0 1.48.26 2.06.68L19.78 2.2z"/></svg>
            Naturalne wykończenie
          </div>
          <h2 class="section-title" data-animate>Olejowanie podłóg drewnianych</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              Olejowanie to <strong class="text-stone-900">naturalna alternatywa dla lakieru</strong>. Olej wnika w strukturę drewna, odżywiając je od środka i podkreślając naturalne usłojenie. Podłoga oddycha i ma ciepły, matowy wygląd.
            </p>
            <p>
              Największą zaletą olejowania jest <strong class="text-stone-900">łatwa naprawa miejscowych uszkodzeń</strong> – zarysowane miejsca można odnawiać punktowo, bez konieczności szlifowania całej podłogi.
            </p>
          </div>
          <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
            {[
              { label: 'Naturalny wygląd', desc: 'Podkreśla usłojenie drewna' },
              { label: 'Punktowa naprawa', desc: 'Bez szlifowania całości' },
              { label: 'Eco-friendly', desc: 'Niskie VOC, przyjazne środowisku' },
              { label: 'Ciepło w dotyku', desc: 'Brak plastikowego efektu' },
            ].map(item => (
              <div class="flex items-start gap-2">
                <svg class="h-4 w-4 text-green-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <div>
                  <p class="text-sm font-medium text-stone-900">{item.label}</p>
                  <p class="text-xs text-stone-500">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-amber-50 p-4 ring-1 ring-amber-100">
            <p class="text-sm font-medium text-stone-900">Bezpłatna wycena – <a href="/kontakt" class="text-amber-700 hover:underline">skontaktuj się z nami</a></p>
            <p class="text-xs text-stone-500 mt-0.5">Wycena po oględzinach podłogi. Nakładamy 2 warstwy oleju.</p>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-2xl bg-stone-100 h-72 lg:h-96" data-animate="fade" style="transition-delay: 200ms">
          {imgs.olejowanie && <Image src={imgs.olejowanie} alt="Olejowanie podłogi drewnianej – naturalny efekt" class="w-full h-full object-cover" width={600} height={400} loading="lazy" format="webp" quality={82} />}
          {!imgs.olejowanie && <div class="absolute inset-0 flex items-center justify-center bg-stone-200/50 text-stone-400 text-sm">Zdjęcie usługi</div>}
        </div>
      </div>
    </div>
  </section>

  <!-- Układanie -->
  <section class="section-padding bg-stone-50" id="ukladanie">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div class="order-2 lg:order-1 relative overflow-hidden rounded-2xl bg-stone-100 h-72 lg:h-96" data-animate="fade" style="transition-delay: 200ms">
          {imgs.ukladanie && <Image src={imgs.ukladanie} alt="Układanie parkietu drewnianego – Książczak Parkiety" class="w-full h-full object-cover" width={600} height={400} loading="lazy" format="webp" quality={82} />}
          {!imgs.ukladanie && <div class="absolute inset-0 flex items-center justify-center bg-stone-200/50 text-stone-400 text-sm">Zdjęcie usługi</div>}
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 rounded-full bg-wood-50 px-4 py-1.5 text-sm font-medium text-wood-600 mb-5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 4h4v4H4V4zm6 0h4v4h-4V4zm6 0h4v4h-4V4zM4 10h4v4H4v-4zm6 0h4v4h-4v-4zm6 0h4v4h-4v-4zM4 16h4v4H4v-4zm6 0h4v4h-4v-4zm6 0h4v4h-4v-4z"/></svg>
            Usługa
          </div>
          <h2 class="section-title" data-animate>Układanie parkietu i desek drewnianych</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              Instalujemy nowe podłogi drewniane w każdym wzorze i gatunku drewna. Doradzamy w doborze materiału, układamy i wykańczamy – kompleksowo, od podłoża po gotową podłogę.
            </p>
            <p>
              Pracujemy z <strong class="text-stone-900">parkietem lamelowym, deskami litymi i warstwowymi oraz mozaiką parkietową</strong>. Układamy jodełkę, cegiełkę, karo i inne wzory.
            </p>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-3">
            {['Parkiet lamelowy', 'Deski drewniane', 'Mozaika parkietowa', 'Jodełka i cegiełka'].map(type => (
              <div class="flex items-center gap-2 text-sm text-stone-700">
                <svg class="h-4 w-4 text-green-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {type}
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-white p-4 ring-1 ring-stone-200">
            <p class="text-sm font-medium text-stone-900">Bezpłatna wycena – <a href="/kontakt" class="text-wood-600 hover:underline">skontaktuj się z nami</a></p>
            <p class="text-xs text-stone-500 mt-0.5">Doradzamy gatunek drewna i wzór dopasowany do wnętrza.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Listwowanie -->
  <section class="section-padding bg-white" id="listwowanie">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-wood-50 px-4 py-1.5 text-sm font-medium text-wood-600 mb-5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 3h18v2H3V3zm0 8h18v2H3v-2zm0 8h18v2H3v-2zm0-4h12v2H3v-2zm0-8h12v2H3V7z"/></svg>
            Wykończenie
          </div>
          <h2 class="section-title" data-animate>Listwowanie</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              Montaż <strong class="text-stone-900">listew przypodłogowych</strong> to ostatni etap wykończenia podłogi, który nadaje pomieszczeniu spójny i elegancki wygląd. Listwy maskują szczeliny dylatacyjne między podłogą a ścianą i chronią tynk przed uszkodzeniami.
            </p>
            <p>
              Montujemy listwy drewniane, MDF i lakierowane – dopasowane kolorem i stylem do podłogi. Wykonujemy też <strong class="text-stone-900">listwy schodowe i wykończeniowe</strong> przy progach i przejściach.
            </p>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-3">
            {['Listwy drewniane', 'Listwy MDF', 'Listwy lakierowane', 'Listwy schodowe'].map(type => (
              <div class="flex items-center gap-2 text-sm text-stone-700">
                <svg class="h-4 w-4 text-green-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {type}
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-stone-100 p-4 ring-1 ring-stone-200">
            <p class="text-sm font-medium text-stone-900">Bezpłatna wycena – <a href="/kontakt" class="text-wood-600 hover:underline">skontaktuj się z nami</a></p>
            <p class="text-xs text-stone-500 mt-0.5">Cena zależy od rodzaju listwy i długości. Wycena po oględzinach.</p>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-2xl bg-stone-100 h-72 lg:h-96" data-animate="fade" style="transition-delay: 200ms">
          {imgs.listwowanie && <Image src={imgs.listwowanie} alt="Montaż listew przypodłogowych – Książczak Parkiety" class="w-full h-full object-cover" width={600} height={400} loading="lazy" format="webp" quality={82} />}
          {!imgs.listwowanie && <div class="absolute inset-0 flex items-center justify-center bg-stone-200/50 text-stone-400 text-sm">Zdjęcie listwowania</div>}
        </div>
      </div>
    </div>
  </section>

  <!-- Schody drewniane -->
  <section class="section-padding bg-stone-50" id="schody">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-stone-100 px-4 py-1.5 text-sm font-medium text-stone-700 mb-5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 20V8l8-5 8 5v12H4zm8-11L7 12v6h10v-6l-5-3zm2 7h-4v-4h4v4z"/></svg>
            Andrzej Książczak
          </div>
          <h2 class="section-title" data-animate>Schody drewniane</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              Produkcja, montaż i renowacja schodów drewnianych – to specjalność <strong class="text-stone-900">Andrzeja Książczaka</strong>, który zajmuje się schodami od ponad 25 lat. Każde schody projektujemy i wykonujemy na wymiar, dopasowując gatunek drewna, konstrukcję i wykończenie do wnętrza i budżetu.
            </p>
            <p>
              Pracujemy z dębem, jesionem, sosną, bukiem i innymi gatunkami. Oprócz nowych schodów wykonujemy też <strong class="text-stone-900">renowację starych stopni</strong> – szlifowanie, naprawa pęknięć, wymiana uszkodzonych elementów, lakierowanie lub olejowanie.
            </p>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-3">
            {['Schody proste', 'Schody zabiegowe', 'Balustrady drewniane', 'Renowacja schodów'].map(type => (
              <div class="flex items-center gap-2 text-sm text-stone-700">
                <svg class="h-4 w-4 text-green-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {type}
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-stone-100 p-4 ring-1 ring-stone-200">
            <p class="text-sm font-medium text-stone-900">Bezpłatna wycena – <a href="/kontakt" class="text-wood-600 hover:underline">skontaktuj się z nami</a></p>
            <p class="text-xs text-stone-500 mt-0.5">Dojedziemy na pomiary i bezpłatnie doradzimy gatunek drewna.</p>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-2xl bg-stone-100 h-72 lg:h-96" data-animate="fade" style="transition-delay: 200ms">
          {imgs.schodGlowne && <Image src={imgs.schodGlowne} alt="Schody drewniane na wymiar – Andrzej Książczak" class="w-full h-full object-cover" width={600} height={400} loading="lazy" format="webp" quality={82} />}
          {!imgs.schodGlowne && <div class="absolute inset-0 flex items-center justify-center bg-stone-200/50 text-stone-400 text-sm">Zdjęcie schodów</div>}
        </div>
      </div>
    </div>
  </section>

  <ContactCTA />
</Layout>
