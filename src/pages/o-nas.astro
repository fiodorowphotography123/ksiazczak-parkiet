---
import Layout from '../layouts/Layout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { localBusinessSchema, krzysztofSchema, andrzejSchema } from '../components/SchemaOrg.astro';
import { CONTACT } from '../config';

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'O nas – Książczak Parkiety i Schody',
  description: 'Rodzinna firma parkieciarsko-schodowa z ponad 25-letnim doświadczeniem. Siedlce, Warszawa i okolice.',
  url: 'https://ksiazczak-parkiet.pl/o-nas',
  mainEntity: {
    '@id': 'https://ksiazczak-parkiet.pl/#business',
  },
};
---

<Layout
  title="O nas – Rodzinna firma parkieciarska od 1999 roku | Książczak Parkiety i Schody"
  description="Poznaj rodzinną firmę Książczak Parkiety i Schody. Działamy od 1999 roku w Siedlcach i Warszawie. Ponad 25 lat doświadczenia w cyklinowaniu, lakierowaniu i schodach drewnianych."
  schema={[localBusinessSchema, aboutPageSchema, krzysztofSchema, andrzejSchema]}
  breadcrumbs={[{ name: 'O nas', url: '/o-nas' }]}
>
  <!-- Header -->
  <section class="bg-stone-50 py-14 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-4 text-sm text-stone-400" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-stone-600 transition-colors">Strona główna</a></li>
          <li>/</li>
          <li class="text-stone-600" aria-current="page">O nas</li>
        </ol>
      </nav>
      <h1 class="text-3xl font-bold text-stone-900 sm:text-4xl" data-animate>
        O nas – rodzinna firma z&nbsp;tradycjami
      </h1>
      <p class="mt-4 max-w-2xl text-base text-stone-600 leading-relaxed sm:text-lg" data-animate style="transition-delay: 100ms">
        Działamy w branży parkieciarskiej od <strong class="text-stone-900">1999 roku</strong>. Jesteśmy małą rodzinną firmą, dla której jakość i indywidualne podejście do klienta są najważniejsze.
      </p>
    </div>
  </section>

  <!-- Historia i doświadczenie -->
  <section class="section-padding bg-white" id="historia">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-wood-50 px-4 py-1.5 text-sm font-medium text-wood-600 mb-5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/></svg>
            Od 1999 roku
          </div>
          <h2 class="section-title" data-animate>Ponad 25 lat doświadczenia w&nbsp;branży</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              <strong class="text-stone-900">Ponad 20-letnie doświadczenie</strong> daje gwarancję profesjonalnego wykonania oferowanych przez nas usług. Od początku stawiamy na jakość materiałów, rzetelność i pełne zaangażowanie w każde zlecenie.
            </p>
            <p>
              Oferujemy wykonanie zarówno <strong class="text-stone-900">podłóg drewnianych</strong>, jak i <strong class="text-stone-900">schodów</strong>. Pracujemy z wykorzystaniem najnowszych technologii – w tym <strong class="text-stone-900">systemu Bona DCS (Dust Containment System)</strong>, który zapewnia niemal całkowicie bezpyłowe szlifowanie podłóg. Stosujemy profesjonalną chemię renomowanych producentów takich jak <strong class="text-stone-900">Blanchon</strong>, <strong class="text-stone-900">Oli Natura</strong> czy <strong class="text-stone-900">Artelit</strong>.
            </p>
            <p>
              Zapewniamy satysfakcję z jakości naszych usług oraz konkurencyjne ceny. Naturalne, drewniane podłogi to <strong class="text-stone-900">najlepszy wybór na długie lata</strong>.
            </p>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-2xl bg-stone-100 h-72 lg:h-96" data-animate="fade" style="transition-delay: 200ms">
          <!-- Placeholder – podmień na własne zdjęcie -->
          <div class="absolute inset-0 flex flex-col items-center justify-center bg-gradient-to-br from-stone-100 to-stone-200 text-stone-400">
            <svg class="h-16 w-16 mb-3 text-stone-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
            <span class="text-sm">Twoje zdjęcie firmy</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nasza filozofia -->
  <section class="section-padding bg-stone-50" id="filozofia">
    <div class="container-max">
      <div class="text-center">
        <h2 class="section-title" data-animate>Indywidualne podejście do każdego zlecenia</h2>
        <p class="section-subtitle mx-auto max-w-2xl" data-animate style="transition-delay: 80ms">
          Do każdego zlecenia podchodzimy w sposób indywidualny. Chętnie pomożemy Ci w doborze odpowiedniej podłogi czy schodów.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            icon: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>',
            title: 'System Bona DCS',
            desc: 'Pracujemy w systemie Bona Dust Containment System – zaawansowanej technologii bezpyłowej z filtracją HEPA, która wychwytuje ponad 99% pyłu drzewnego.',
          },
          {
            icon: '<path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>',
            title: 'Rodzinna firma',
            desc: 'Jesteśmy małą firmą rodzinną. Dbamy o relacje z klientami i traktujemy każde zlecenie jak własny dom.',
          },
          {
            icon: '<path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
            title: 'Renomowane produkty',
            desc: 'Stosujemy profesjonalną chemię Blanchon, Oli Natura i Artelit – materiały sprawdzone przez lata.',
          },
          {
            icon: '<path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>',
            title: 'Konkurencyjne ceny',
            desc: 'Oferujemy uczciwe, konkurencyjne ceny. Bezpłatna wycena po oględzinach – bez ukrytych kosztów.',
          },
        ].map((item, i) => (
          <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-stone-100 transition-shadow hover:shadow-md" data-animate style={`transition-delay: ${160 + i * 80}ms`}>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-wood-50 text-wood-600">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            </div>
            <h3 class="mt-4 text-base font-semibold text-stone-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Nasi eksperci -->
  <section class="section-padding bg-white" id="zespol">
    <div class="container-max">
      <div class="text-center">
        <h2 class="section-title" data-animate>Nasi eksperci</h2>
        <p class="section-subtitle mx-auto max-w-xl" data-animate style="transition-delay: 80ms">
          Firmę tworzą bracia Książczak – każdy specjalista w swojej dziedzinie.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 max-w-3xl mx-auto">
        <!-- Krzysztof -->
        <div class="rounded-2xl bg-stone-50 p-6 ring-1 ring-stone-100 text-center" data-animate style="transition-delay: 160ms">
          <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-wood-100 text-wood-600 mb-5">
            <svg class="h-12 w-12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-stone-900">Krzysztof Książczak</h3>
          <p class="mt-1 text-sm font-medium text-wood-600">Specjalista – parkiety i podłogi</p>
          <p class="mt-3 text-sm leading-relaxed text-stone-600">
            Odpowiada za cyklinowanie bezpyłowe, lakierowanie, olejowanie i układanie podłóg drewnianych. Ponad 25 lat doświadczenia w branży parkieciarskiej.
          </p>
          <a
            href={CONTACT.phoneHref}
            class="mt-5 inline-flex items-center gap-2 rounded-full bg-wood-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-wood-600 active:scale-95"
            aria-label={`Zadzwoń do Krzysztofa: ${CONTACT.phone}`}
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            {CONTACT.phone}
          </a>
        </div>

        <!-- Andrzej -->
        <div class="rounded-2xl bg-stone-50 p-6 ring-1 ring-stone-100 text-center" data-animate style="transition-delay: 240ms">
          <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-stone-200 text-stone-500 mb-5">
            <svg class="h-12 w-12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-stone-900">Andrzej Książczak</h3>
          <p class="mt-1 text-sm font-medium text-stone-500">Specjalista – schody drewniane</p>
          <p class="mt-3 text-sm leading-relaxed text-stone-600">
            Zajmuje się produkcją, montażem i renowacją schodów drewnianych. Schody na wymiar z dębu, jesionu, sosny i innych gatunków drewna.
          </p>
          <a
            href={CONTACT.phoneSecondHref}
            class="mt-5 inline-flex items-center gap-2 rounded-full bg-stone-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-stone-800 active:scale-95"
            aria-label={`Zadzwoń do Andrzeja: ${CONTACT.phoneSecond}`}
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            {CONTACT.phoneSecond}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Producenci, z którymi pracujemy -->
  <section class="section-padding bg-stone-50" id="producenci">
    <div class="container-max">
      <div class="text-center">
        <h2 class="section-title" data-animate>Pracujemy z najlepszymi producentami</h2>
        <p class="section-subtitle mx-auto max-w-xl" data-animate style="transition-delay: 80ms">
          Stosujemy wyłącznie profesjonalną chemię i materiały renomowanych marek, które gwarantują trwałość i estetykę wykończenia.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-3 max-w-3xl mx-auto">
        {[
          {
            name: 'Blanchon',
            desc: 'Francuski producent lakierów, olejów i preparatów do pielęgnacji podłóg drewnianych. Klasa premium.',
            color: 'bg-blue-50 text-blue-700 ring-blue-100',
          },
          {
            name: 'Oli Natura',
            desc: 'Naturalne oleje i woski do drewna. Ekologiczne produkty podkreślające piękno naturalnego drewna.',
            color: 'bg-green-50 text-green-700 ring-green-100',
          },
          {
            name: 'Artelit',
            desc: 'Polski producent klejów, lakierów i materiałów do montażu podłóg. Sprawdzona jakość od lat.',
            color: 'bg-amber-50 text-amber-700 ring-amber-100',
          },
        ].map((brand, i) => (
          <div class={`rounded-2xl p-6 ring-1 text-center ${brand.color}`} data-animate style={`transition-delay: ${160 + i * 80}ms`}>
            <h3 class="text-lg font-bold">{brand.name}</h3>
            <p class="mt-2 text-sm leading-relaxed opacity-80">{brand.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Liczby -->
  <section class="section-padding bg-stone-900 text-white" id="liczby">
    <div class="container-max">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl" data-animate>Nasze osiągnięcia w liczbach</h2>
      </div>
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {[
          { value: '25+', label: 'lat doświadczenia', sublabel: 'od 1999 roku' },
          { value: '1000+', label: 'zrealizowanych zleceń', sublabel: 'podłogi i schody' },
          { value: '100 km', label: 'zasięg od Siedlec', sublabel: 'w tym Warszawa' },
          { value: '5.0★', label: 'ocena klientów', sublabel: 'Google Reviews' },
        ].map((stat, i) => (
          <div class="text-center" data-animate style={`transition-delay: ${i * 80}ms`}>
            <div class="text-3xl font-bold text-wood-400 sm:text-4xl">{stat.value}</div>
            <div class="mt-1 text-sm font-medium text-stone-300">{stat.label}</div>
            <div class="mt-0.5 text-xs text-stone-500">{stat.sublabel}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactCTA
    title="Skontaktuj się z nami"
    subtitle="Chętnie pomożemy w wyborze podłogi lub schodów. Bezpłatna wycena – zadzwoń lub napisz, a odpowiemy od ręki."
  />
</Layout>
