---
import Layout from '../layouts/Layout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { localBusinessSchema } from '../components/SchemaOrg.astro';

const PHONE = '+48 XXX XXX XXX';
const PHONE_HREF = 'tel:+48XXXXXXXXX';

const priceSchema = {
  '@context': 'https://schema.org',
  '@type': 'PriceSpecification',
  priceCurrency: 'PLN',
  eligibleRegion: { '@type': 'City', name: 'Siedlce' },
};
---

<Layout
  title="Cennik Cyklinowania Parkietu 2025 – Siedlce i okolice | Książczak"
  description="Aktualne ceny cyklinowania bezpyłowego parkietu i podłóg drewnianych. Siedlce, Warszawa. Od 25 zł/m². Bezpłatna wycena na miejscu. ☎ Zadzwoń!"
  schema={[localBusinessSchema, priceSchema]}
  breadcrumbs={[{ name: 'Cennik', url: '/cennik' }]}
>
  <!-- Header -->
  <section class="bg-stone-50 py-14 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-4 text-sm text-stone-400" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-stone-600 transition-colors">Strona główna</a></li>
          <li>/</li>
          <li class="text-stone-600" aria-current="page">Cennik</li>
        </ol>
      </nav>
      <h1 class="text-4xl font-extrabold text-stone-900 sm:text-5xl">Cennik usług</h1>
      <p class="mt-4 max-w-2xl text-lg text-stone-600 leading-relaxed">
        Transparentne ceny bez ukrytych kosztów. Wycenę ostateczną przygotowujemy po obejrzeniu podłogi – <strong>to zawsze jest bezpłatne</strong>.
      </p>
      <p class="mt-2 text-sm text-stone-400">Aktualizacja: 2025 · Ceny orientacyjne, netto</p>
    </div>
  </section>

  <!-- Cennik cyklinowania -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <h2 class="section-title">Cyklinowanie bezpyłowe podłóg</h2>
      <p class="mt-3 text-stone-600">Cena za szlifowanie podłogi drewnianej maszyną bezpyłową, bez wykończenia.</p>

      <div class="mt-8 overflow-hidden rounded-2xl ring-1 ring-stone-200">
        <table class="w-full text-sm">
          <thead class="bg-stone-50">
            <tr>
              <th class="px-6 py-4 text-left font-semibold text-stone-900">Usługa</th>
              <th class="px-6 py-4 text-right font-semibold text-stone-900">Cena od</th>
              <th class="px-6 py-4 text-right font-semibold text-stone-900 hidden sm:table-cell">Jednostka</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-100">
            {[
              { service: 'Szlifowanie (cyklinowanie) zgrubne + końcowe', price: '25 zł', unit: '/m²' },
              { service: 'Szlifowanie z szpachlowaniem szpar', price: '30 zł', unit: '/m²' },
              { service: 'Szlifowanie trudnych podłóg (bardzo zniszczone)', price: '40 zł', unit: '/m²' },
              { service: 'Szlifowanie schodów (stopień)', price: '50 zł', unit: '/stopień' },
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-stone-50/50'}>
                <td class="px-6 py-4 text-stone-700">{row.service}</td>
                <td class="px-6 py-4 text-right font-semibold text-wood-600">{row.price}</td>
                <td class="px-6 py-4 text-right text-stone-400 hidden sm:table-cell">{row.unit}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2 class="section-title mt-14">Wykończenie podłóg</h2>
      <p class="mt-3 text-stone-600">Ceny za wykończenie po cyklinowaniu (lakierowanie lub olejowanie).</p>

      <div class="mt-8 overflow-hidden rounded-2xl ring-1 ring-stone-200">
        <table class="w-full text-sm">
          <thead class="bg-stone-50">
            <tr>
              <th class="px-6 py-4 text-left font-semibold text-stone-900">Usługa</th>
              <th class="px-6 py-4 text-right font-semibold text-stone-900">Cena od</th>
              <th class="px-6 py-4 text-right font-semibold text-stone-900 hidden sm:table-cell">Jednostka</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-100">
            {[
              { service: 'Lakierowanie (2 warstwy lakieru wodnego)', price: '20 zł', unit: '/m²' },
              { service: 'Lakierowanie (3 warstwy, premium)', price: '28 zł', unit: '/m²' },
              { service: 'Olejowanie (2 warstwy oleju)', price: '25 zł', unit: '/m²' },
              { service: 'Olejowanie z woskowaniem', price: '32 zł', unit: '/m²' },
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-stone-50/50'}>
                <td class="px-6 py-4 text-stone-700">{row.service}</td>
                <td class="px-6 py-4 text-right font-semibold text-wood-600">{row.price}</td>
                <td class="px-6 py-4 text-right text-stone-400 hidden sm:table-cell">{row.unit}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Packages -->
      <h2 class="section-title mt-14">Pakiety kompleksowe</h2>
      <p class="mt-3 text-stone-600">Szlifowanie + wykończenie w jednej cenie – najczęściej wybierana opcja.</p>

      <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {[
          {
            name: 'Pakiet BASIC',
            desc: 'Szlifowanie + 2× lakier wodny',
            price: 'od 45 zł/m²',
            features: ['Szlifowanie bezpyłowe', '2 warstwy lakieru', 'Sprzątanie po pracy'],
            highlighted: false,
          },
          {
            name: 'Pakiet STANDARD',
            desc: 'Szlifowanie + szpachlowanie + 3× lakier',
            price: 'od 58 zł/m²',
            features: ['Szlifowanie bezpyłowe', 'Szpachlowanie szpar', '3 warstwy lakieru premium', 'Sprzątanie po pracy'],
            highlighted: true,
          },
          {
            name: 'Pakiet OIL',
            desc: 'Szlifowanie + olejowanie naturalne',
            price: 'od 50 zł/m²',
            features: ['Szlifowanie bezpyłowe', 'Szpachlowanie szpar', '2 warstwy oleju', 'Wosk końcowy'],
            highlighted: false,
          },
        ].map(pkg => (
          <article class={`rounded-2xl p-6 flex flex-col ${
            pkg.highlighted
              ? 'bg-wood-500 text-white ring-2 ring-wood-500 shadow-lg shadow-wood-500/20'
              : 'bg-stone-50 ring-1 ring-stone-200'
          }`}>
            {pkg.highlighted && (
              <div class="mb-3 inline-flex w-fit items-center rounded-full bg-white/20 px-3 py-0.5 text-xs font-semibold">
                Najpopularniejszy
              </div>
            )}
            <h3 class={`text-lg font-bold ${pkg.highlighted ? 'text-white' : 'text-stone-900'}`}>{pkg.name}</h3>
            <p class={`text-sm mt-1 ${pkg.highlighted ? 'text-white/80' : 'text-stone-500'}`}>{pkg.desc}</p>
            <p class={`text-2xl font-extrabold mt-4 ${pkg.highlighted ? 'text-white' : 'text-wood-600'}`}>{pkg.price}</p>
            <ul class={`mt-5 space-y-2 text-sm flex-1 ${pkg.highlighted ? 'text-white/90' : 'text-stone-700'}`}>
              {pkg.features.map(f => (
                <li class="flex items-center gap-2">
                  <svg class={`h-4 w-4 shrink-0 ${pkg.highlighted ? 'text-white' : 'text-green-500'}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="/kontakt"
              class={`mt-6 inline-flex items-center justify-center rounded-full py-3 px-6 text-sm font-semibold transition-all active:scale-95 ${
                pkg.highlighted
                  ? 'bg-white text-wood-600 hover:bg-wood-50'
                  : 'bg-wood-500 text-white hover:bg-wood-600'
              }`}
            >
              Zamów wycenę
            </a>
          </article>
        ))}
      </div>

      <!-- Info box -->
      <div class="mt-12 rounded-2xl bg-amber-50 p-6 ring-1 ring-amber-100">
        <div class="flex gap-4">
          <div class="text-2xl" aria-hidden="true">ℹ️</div>
          <div class="text-sm text-stone-700 leading-relaxed">
            <p class="font-semibold text-stone-900">Ważna informacja o cenach</p>
            <ul class="mt-2 space-y-1 list-disc ml-4">
              <li>Podane ceny są orientacyjne i mogą się różnić w zależności od stanu podłogi, jej rodzaju i lokalizacji.</li>
              <li>Dojazd gratis w promieniu 40 km od Siedlec. Powyżej – koszt ustalamy indywidualnie.</li>
              <li>Wycena ostateczna jest zawsze <strong>bezpłatna</strong> – dojedziemy na miejsce i ocenimy podłogę.</li>
              <li>Ceny dotyczą powierzchni min. 15 m².</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA
    title="Uzyskaj dokładną wycenę"
    subtitle="Zadzwoń lub wypełnij formularz – dojedziemy bezpłatnie na oględziny do Siedlec, Warszawy i okolic."
  />
</Layout>
