---
import { CONTACT, BUSINESS } from '../config';
const PHONE = CONTACT.phone;
const PHONE_HREF = CONTACT.phoneHref;
const EMAIL = CONTACT.email;
const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-900 text-stone-300">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-white hover:text-wood-300 transition-colors">
          <img src="/parkiety-logo-bialy.png" alt="Książczak Parkiety i Schody" width="160" height="60" class="h-10 w-auto" />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-stone-400">
          Rodzinna firma z ponad 25-letnim doświadczeniem. Specjalizujemy się w cyklinowaniu bezpyłowym podłóg drewnianych i schodach drewnianych.
        </p>
        <p class="mt-3 text-xs text-stone-500">Siedlce i okolice · Warszawa</p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-stone-200">Usługi</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/cyklinowanie-bezpylowe" class="text-stone-400 hover:text-wood-300 transition-colors">Cyklinowanie bezpyłowe</a></li>
          <li><a href="/uslugi#lakierowanie" class="text-stone-400 hover:text-wood-300 transition-colors">Lakierowanie podłóg</a></li>
          <li><a href="/uslugi#olejowanie" class="text-stone-400 hover:text-wood-300 transition-colors">Olejowanie podłóg</a></li>
          <li><a href="/uslugi#ukladanie" class="text-stone-400 hover:text-wood-300 transition-colors">Układanie parkietu</a></li>
          <li><a href="/schody-drewniane" class="text-stone-400 hover:text-wood-300 transition-colors">Schody drewniane</a></li>
        </ul>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-stone-200">Firma</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/realizacje" class="text-stone-400 hover:text-wood-300 transition-colors">Nasze realizacje</a></li>
          <li><a href="/kontakt" class="text-stone-400 hover:text-wood-300 transition-colors">Kontakt</a></li>
          <li>
            <a href="https://www.facebook.com/profile.php?id=100087186586035" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-wood-300 transition-colors">
              Facebook
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-stone-200">Kontakt</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a href={PHONE_HREF} class="flex items-center gap-2 text-stone-400 hover:text-wood-300 transition-colors">
              <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              {PHONE} <span class="text-stone-500">({CONTACT.phoneLabel})</span>
            </a>
          </li>
          <li>
            <a href={CONTACT.phoneSecondHref} class="flex items-center gap-2 text-stone-400 hover:text-wood-300 transition-colors">
              <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              {CONTACT.phoneSecond} <span class="text-stone-500">({CONTACT.phoneSecondLabel})</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${EMAIL}`} class="flex items-center gap-2 text-stone-400 hover:text-wood-300 transition-colors">
              <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
              {EMAIL}
            </a>
          </li>
          <li class="flex items-start gap-2 text-stone-400">
            <svg class="h-4 w-4 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            ul. 11-go Listopada 61<br/>08-140 Mordy, woj. mazowieckie<br/>Obsługujemy teren do 100 km
          </li>
        </ul>
      </div>
    </div>

    <!-- Obszar działania -->
    <div class="mt-10 border-t border-stone-800 pt-8">
      <p class="text-xs text-stone-500 text-center">
        Obsługiwane miasta: <span class="text-stone-400">Siedlce · Warszawa · Mińsk Mazowiecki · Łuków · Sokołów Podlaski · Biała Podlaska</span>
        i cały obszar w promieniu 100 km od Siedlec.
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="mt-6 flex flex-col items-center justify-between gap-3 border-t border-stone-800 pt-6 text-xs text-stone-500 sm:flex-row">
      <p>© {currentYear} Książczak Parkiety i Schody. Wszelkie prawa zastrzeżone.</p>
      <p>NIP: {BUSINESS.nip} · Siedlce, Polska</p>
    </div>
  </div>
</footer>
