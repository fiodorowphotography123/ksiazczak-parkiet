---
/**
 * Galeria realizacji — automatyczna optymalizacja zdjęć
 *
 * JAK DODAWAĆ ZDJĘCIA:
 *   1. Wrzuć zdjęcia do folderu:  src/assets/galeria/
 *   2. Nazwij je parami:           przed-1.jpg / po-1.jpg
 *                                  przed-2.jpg / po-2.jpg  itd.
 *   3. Astro automatycznie:        konwertuje do WebP, kompresuje,
 *                                  tworzy srcset, dodaje lazy loading
 *
 * Obsługiwane formaty: .jpg, .jpeg, .png, .webp, .avif
 */
import { Image } from 'astro:assets';

export interface Props {
  limit?: number;
  showLink?: boolean;
}

const { limit = 6, showLink = true } = Astro.props;

// import.meta.glob musi być literałem (nie zmienną) – ładuje wszystkie obrazy z src/assets/galeria/
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/galeria/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);

// Wyciągnij ImageMetadata z modułów
const allFiles = Object.entries(modules).map(([path, mod]) => ({
  path,
  image: mod.default,
  filename: path.split('/').pop()!.replace(/\.[^.]+$/, ''), // np. "przed-1"
}));

// Pogrupuj w pary przed/po na podstawie numeru
const pairsMap = new Map<number, { przed?: ImageMetadata; po?: ImageMetadata }>();
for (const file of allFiles) {
  const beforeMatch = file.filename.match(/^przed-(\d+)$/i);
  const afterMatch = file.filename.match(/^po-(\d+)$/i);
  if (beforeMatch) {
    const n = parseInt(beforeMatch[1]);
    const pair = pairsMap.get(n) ?? {};
    pair.przed = file.image;
    pairsMap.set(n, pair);
  } else if (afterMatch) {
    const n = parseInt(afterMatch[1]);
    const pair = pairsMap.get(n) ?? {};
    pair.po = file.image;
    pairsMap.set(n, pair);
  }
}

// Posortuj po numerze i ogranicz do `limit`
const pairs = [...pairsMap.entries()]
  .sort(([a], [b]) => a - b)
  .slice(0, limit)
  .map(([n, pair]) => ({ n, ...pair }));

// Metadane dla każdej pary (alt, lokalizacja) – dodaj tyle ile masz par
const meta: Record<number, { alt: string; room: string }> = {
  1: { alt: 'Cyklinowanie parkietu – przed i po – realizacja Siedlce', room: 'Salon, Siedlce' },
  2: { alt: 'Renowacja podłogi drewnianej – przed i po – Warszawa', room: 'Sypialnia, Warszawa' },
  3: { alt: 'Szlifowanie desek – przed i po – Mińsk Mazowiecki', room: 'Korytarz, Mińsk Maz.' },
  4: { alt: 'Cyklinowanie bezpyłowe parkietu – przed i po', room: 'Salon' },
  5: { alt: 'Renowacja mozaiki parkietowej – przed i po', room: 'Gabinet' },
  6: { alt: 'Olejowanie podłogi drewnianej – przed i po', room: 'Pokój' },
};

const hasPairs = pairs.length > 0;
---

<section class="section-padding bg-stone-50" id="realizacje" aria-labelledby="gallery-heading">
  <div class="container-max">
    <div class="text-center">
      <h2 class="section-title" id="gallery-heading">Nasze realizacje</h2>
      <p class="section-subtitle mx-auto max-w-xl">
        Efekty naszej pracy mówią same za siebie. Każda podłoga to nowa historia.
      </p>
    </div>

    {hasPairs ? (
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {pairs.map(({ n, przed, po }) => {
          const m = meta[n] ?? { alt: `Realizacja nr ${n}`, room: `Realizacja ${n}` };
          return (
            <article class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-stone-100 transition-all hover:shadow-md">
              <div class="grid grid-cols-2 divide-x divide-stone-100">
                <!-- Before -->
                <div class="relative overflow-hidden">
                  <div class="absolute left-2 top-2 z-10 rounded-full bg-black/60 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm">Przed</div>
                  {przed ? (
                    <Image
                      src={przed}
                      alt={`Przed – ${m.alt}`}
                      width={400}
                      height={300}
                      class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      format="webp"
                      quality={82}
                    />
                  ) : (
                    <div class="h-48 w-full bg-gradient-to-br from-stone-200 to-stone-300 flex items-center justify-center text-xs text-stone-400">brak zdjęcia</div>
                  )}
                </div>
                <!-- After -->
                <div class="relative overflow-hidden">
                  <div class="absolute right-2 top-2 z-10 rounded-full bg-wood-500/90 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm">Po</div>
                  {po ? (
                    <Image
                      src={po}
                      alt={`Po – ${m.alt}`}
                      width={400}
                      height={300}
                      class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      format="webp"
                      quality={82}
                    />
                  ) : (
                    <div class="h-48 w-full bg-gradient-to-br from-wood-200 to-wood-400 flex items-center justify-center text-xs text-white">brak zdjęcia</div>
                  )}
                </div>
              </div>
              <div class="px-4 py-3">
                <p class="text-sm font-medium text-stone-700">{m.room}</p>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      /* Placeholder gdy brak zdjęć w src/assets/galeria/ */
      <div class="mt-10 rounded-2xl bg-white p-10 text-center ring-1 ring-stone-100">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-stone-100">
          <svg class="h-8 w-8 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
          </svg>
        </div>
        <p class="mt-4 text-sm font-semibold text-stone-700">Zdjęcia pojawią się tutaj</p>
        <p class="mt-1 text-xs text-stone-400">
          Wrzuć zdjęcia do <code class="rounded bg-stone-100 px-1 py-0.5">src/assets/galeria/</code><br/>
          Nazwy: <code class="rounded bg-stone-100 px-1 py-0.5">przed-1.jpg</code> i <code class="rounded bg-stone-100 px-1 py-0.5">po-1.jpg</code>, itd.
        </p>
      </div>
    )}

    {showLink && (
      <div class="mt-10 text-center">
        <a href="/realizacje" class="btn-secondary">
          Zobacz wszystkie realizacje
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
