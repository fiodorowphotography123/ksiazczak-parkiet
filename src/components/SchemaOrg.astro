---
import { CONTACT, ADDRESS, SITE } from '../config';

// Central place for all schema.org structured data
// Exported as individual schema objects to be passed to Layout

export const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  alternateName: ['Krzysztof Książczak Parkiety', 'Książczak Cyklinowanie Siedlce'],
  description:
    'Profesjonalne cyklinowanie bezpyłowe podłóg drewnianych, parkietów, desek i schodów drewnianych. Ponad 25 lat doświadczenia. Obsługujemy Siedlce, Warszawę i okolicę w promieniu 100 km.',
  url: SITE.url,
  telephone: CONTACT.phoneHref.replace('tel:', ''),
  email: CONTACT.email,
  address: {
    '@type': 'PostalAddress',
    ...(ADDRESS.street ? { streetAddress: ADDRESS.street } : {}),
    addressLocality: ADDRESS.city,
    addressRegion: ADDRESS.region,
    postalCode: ADDRESS.postalCode,
    addressCountry: ADDRESS.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: ADDRESS.lat,
    longitude: ADDRESS.lng,
  },
  areaServed: [
    { '@type': 'City', name: 'Mordy' },
    { '@type': 'City', name: 'Siedlce' },
    { '@type': 'City', name: 'Warszawa' },
    { '@type': 'City', name: 'Mińsk Mazowiecki' },
    { '@type': 'City', name: 'Łuków' },
    { '@type': 'City', name: 'Sokołów Podlaski' },
    { '@type': 'City', name: 'Biała Podlaska' },
    { '@type': 'State', name: 'Mazowieckie' },
  ],
  priceRange: '$$',
  currenciesAccepted: 'PLN',
  paymentAccepted: 'Cash, Bank Transfer',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '07:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '08:00',
      closes: '14:00',
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Usługi parkieciarskie',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Cyklinowanie bezpyłowe parkietu w systemie Bona DCS',
          description: 'Szlifowanie podłóg drewnianych w systemie Bona DCS (Dust Containment System) z filtracją HEPA – ponad 99% pyłu wychwytywane u źródła',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Lakierowanie podłóg drewnianych',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Olejowanie podłóg drewnianych',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Układanie parkietu i desek drewnianych',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Schody drewniane – montaż i renowacja',
        },
      },
    ],
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    bestRating: '5',
    worstRating: '1',
    ratingCount: '47', // ← zaktualizuj wg rzeczywistej liczby opinii
  },
  sameAs: [
    CONTACT.facebook,
    CONTACT.google,
  ],
};

export const krzysztofSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Krzysztof Książczak',
  jobTitle: 'Mistrz parkieciarz',
  description: 'Specjalista cyklinowania bezpyłowego i renowacji podłóg drewnianych z ponad 25-letnim doświadczeniem.',
  telephone: CONTACT.phoneHref.replace('tel:', ''),
  worksFor: { '@id': `${SITE.url}/#business` },
  url: SITE.url,
};

export const andrzejSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Andrzej Książczak',
  jobTitle: 'Mistrz stolarz – schody drewniane',
  description: 'Specjalista produkcji, montażu i renowacji schodów drewnianych z ponad 25-letnim doświadczeniem.',
  telephone: CONTACT.phoneSecondHref.replace('tel:', ''),
  worksFor: { '@id': `${SITE.url}/#business` },
  url: `${SITE.url}/schody-drewniane`,
};

export const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Jak przebiega profesjonalne cyklinowanie parkietu?',
  description:
    'Proces profesjonalnego cyklinowania bezpyłowego podłóg drewnianych krok po kroku.',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Bezpłatna wycena',
      text: 'Kontakt telefoniczny lub przez formularz. Dojedziemy na miejsce i bezpłatnie ocenimy stan podłogi.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Cyklinowanie bezpyłowe',
      text: 'Szlifowanie maszyną z systemem odsysania pyłu – ponad 99% pyłu zatrzymane przez maszynę.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Lakierowanie lub olejowanie',
      text: 'Wykończenie podłogi lakierem lub olejem wg wyboru klienta. Podłoga jak nowa.',
    },
  ],
};
---
<!-- This component exports schemas as JS objects – use them in page frontmatter -->
